{
  "schemaVersion": "1.0",
  
  "metadata": {
      "standard": "AASTP-1",
      "edition": "Edition D Version 1",
      "chapter": "Chapter 1",
      "dataType": "Structures",
      "version": "1.0.0",
      "lastUpdated": "2026-07-11"
  },

  "formulas": {

    "cube_root": {
      "name": "Cube Root Distance Formula",
      "description": "Standard explosive quantity-distance relationship.",
      "solvable": true,
      "units": {
        "input": "kg",
        "output": "m"
      },
      "parameters": {
        "input": "neq",
        "output": "distance"
      },
      "forwardExpression": "coefficient * pow(neq, 1.0/3.0)",
      "reverseExpression": "pow(distance/coefficient, 3.0)"
    },

    "cube_root_squared": {
      "name": "Cube Root Squared Formula",
      "description": "Used for certain fragment and hazard calculations.",
      "solvable": true,
      "units": {
        "input": "kg",
        "output": "m"
      },
      "parameters": {
        "input": "neq",
        "output": "distance"
      },
      "forwardExpression": "coefficient * pow(neq, 2.0/3.0)",
      "reverseExpression": "pow(distance/coefficient, 1.5)"
    },

    "square_root": {
      "name": "Square Root Formula",
      "description": "Used where distance scales with square root of NEQ.",
      "solvable": true,
      "units": {
        "input": "kg",
        "output": "m"
      },
      "parameters": {
        "input": "neq",
        "output": "distance"
      },
      "forwardExpression": "coefficient * sqrt(neq)",
      "reverseExpression": "pow(distance/coefficient, 2.0)"
    },

    "constant_distance": {
      "name": "Constant Distance",
      "description": "Fixed distance independent of NEQ.",
      "solvable": false,
      "units": {
        "output": "m"
      },
      "parameters": [
        "distance"
      ],
      "forwardExpression": "distance"
    }
  }
}

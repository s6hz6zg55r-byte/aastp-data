{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://aastp.org/schemas/interaction_rules.schema.json",

    "title": "Interaction Rules",

    "type": "object",

    "properties": {
        "schemaVersion": {
            "$ref": "https://aastp.org/schemas/defs/common.schema.json#/$defs/schemaVersion"
        },

        "metadata": {
            "$ref": "https://aastp.org/schemas/defs/common.schema.json#/$defs/metadata"
        },

        "interactionRules": {
            "type": "object",
            "patternProperties": {
                "^INT[0-9]{3}$": {
                    "$ref": "#/$defs/interactionRule"
                }
            },
            "additionalProperties": false
        }
    },

    "$defs": {
        "interactionRule": {
            "type": "object",

            "properties": {
                "id": {
                    "type": "string",
                    "pattern": "^INT[0-9]{3}$"
                },

                "source": {
                    "$ref": "#/$defs/source"
                },

                "conditions": {
                    "$ref": "#/$defs/conditions"
                },

                "effects": {
                    "$ref": "#/$defs/effects"
                }
            },

            "required": [
                "id",
                "source",
                "conditions",
                "effects"
            ],

            "additionalProperties": false
        },
        "source": {
            "type": "object",

            "properties": {
                "document": {
                    "type": "string"
                },

                "reference": {
                    "type": "object",

                    "properties": {
                        "table": {
                            "type": "integer"
                        },

                        "row": {
                            "type": "integer"
                        },

                        "column": {
                            "type": "string"
                        }
                    },

                    "required": [
                        "table",
                        "row",
                        "column"
                    ],

                    "additionalProperties": false
                }
            },

            "required": [
                "document",
                "reference"
            ],

            "additionalProperties": false
        },
        "conditions": {
            "type": "object",

            "properties": {

                "pesType": {
                    "type": "string",
                    "pattern": "^PES[0-9A-Z]{3}$"
                },

                "esType": {
                    "type": "string",
                    "pattern": "^ES[0-9A-Z]{3}$"
                },

                "orientation": {
                    "type": "object",

                    "properties": {
                        "pes": {
                            "enum": [
                                "front",
                                "side",
                                "rear"
                            ]
                        },

                        "es": {
                            "enum": [
                                "front",
                                "side",
                                "rear"
                            ]
                        }
                    },

                    "required": [
                        "pes",
                        "es"
                    ],

                    "additionalProperties": false
                }
            },

            "required": [
                "pesType",
                "esType",
                "orientation"
            ],

            "additionalProperties": false
        },
        "effects": {
            "type": "object",
            "minProperties": 1,

            "patternProperties": {
                "^EFF[0-9]{3}$": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                        "$ref": "#/$defs/effectRule"
                    }
                }
            },

            "additionalProperties": false
        },
        "effectRule": {
            "oneOf": [
                {
                    "type": "object",
                    "properties": {
                        "hazard": {
                            "type": "string",
                            "pattern": "^HD[0-9]{3}$"
                        },
                        "status": {
                            "enum": [
                                "N_A",
                                "NO_QD"
                            ]
                        }
                    },
                    "required": [
                        "hazard",
                        "status"
                    ],
                    "additionalProperties": false
                },
                {
                    "type": "object",
                    "properties": {
                        "hazard": {
                            "type": "string",
                            "pattern": "^HD[0-9]{3}$"
                        },
                        "distanceRule": {
                            "type": "string",
                            "pattern": "^[A-Z0-9]+$"
                        },
                        "inputBasis": {
                            "enum": [
                                "NEQ",
                                "MCE"
                            ]
                        },
                        "protectionLevel": {
                            "type": "string",
                            "pattern": "^PL[0-9]{3}$"
                        },
                        "constraints": {
                            "type": "array",
                            "items": {
                                "type": "string",
                                "pattern": "^CV[0-9]{3}$"
                            }
                        }
                    },
                    "required": [
                        "hazard",
                        "distanceRule",
                        "inputBasis",
                        "protectionLevel",
                        "constraints"
                    ],
                    "additionalProperties": false
                }
            ]
        }
    },
    "required": [
        "schemaVersion",
        "metadata",
        "interactionRules"
    ],

    "additionalProperties": false
}